{
  "name": "near-passkey-wallet",
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run build:sdk && vite build",
    "build:sdk": "npm run build -w @passkey/sdk",
    "preview": "vite preview",
    "deploy": "./scripts/deploy.sh",
    "deploy:frontend": "npm run build && npx wrangler pages deploy dist --project-name=near-passkey-wallet"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@passkey/sdk": "*",
    "@yudiel/react-qr-scanner": "^2.6.0",
    "bn.js": "^5.2.0",
    "bs58": "^6.0.0",
    "ethers": "^6.13.0",
    "near-api-js": "^5.1.0",
    "qrcode.react": "^4.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tweetnacl": "^1.0.3",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
